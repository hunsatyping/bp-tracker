<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>บันทึกความดันโลหิต</title>
<script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
* { box-sizing: border-box; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; padding: 16px; background: #fafafa; color: #222; }
h1 { font-size: 18px; margin: 0 0 12px; }
#userInfo { font-size: 13px; color: #666; margin-bottom: 16px; }
form { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
label { display: flex; flex-direction: column; font-size: 13px; gap: 4px; }
input { padding: 8px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
button { padding: 10px; border: none; border-radius: 4px; background: #2c3e50; color: #fff; font-size: 14px; cursor: pointer; }
.tabs { display: flex; gap: 8px; margin-bottom: 12px; }
.tabs button { flex: 1; background: #eee; color: #333; }
.tabs button.active { background: #2c3e50; color: #fff; }
table { width: 100%; border-collapse: collapse; font-size: 13px; background: #fff; }
th, td { border: 1px solid #ddd; padding: 6px; text-align: center; }
th { background: #f0f0f0; }
.del { background: #c0392b; padding: 4px 8px; font-size: 12px; }
canvas { background: #fff; padding: 8px; border-radius: 4px; }
</style>
</head>
<body>
<div id="app">
  <h1>บันทึกความดันโลหิต</h1>
  <div id="userInfo">กำลังโหลด...</div>
  <form id="bpForm">
    <label>วันที่<input type="date" id="date" required></label>
    <label>เวลา<input type="time" id="time" required></label>
    <label>ค่าบน (Systolic)<input type="number" id="systolic" required></label>
    <label>ค่าล่าง (Diastolic)<input type="number" id="diastolic" required></label>
    <label>ชีพจร (Pulse)<input type="number" id="pulse"></label>
    <label>หมายเหตุ<input type="text" id="note"></label>
    <button type="submit">บันทึก</button>
  </form>
  <div class="tabs">
    <button id="tabTable" class="active">ตาราง</button>
    <button id="tabChart">กราฟ</button>
  </div>
  <div id="tableView">
    <table id="bpTable">
      <thead><tr><th>วันที่</th><th>เวลา</th><th>บน</th><th>ล่าง</th><th>ชีพจร</th><th>หมายเหตุ</th><th></th></tr></thead>
      <tbody></tbody>
    </table>
  </div>
  <div id="chartView" style="display:none">
    <canvas id="bpChart"></canvas>
  </div>
</div>
<script>
const LIFF_ID = "YOUR_LIFF_ID";
let userId = "guest";
let records = [];
let chartInstance = null;
let autoTime = true;
let clockTimer = null;

function startClock() {
  if (clockTimer) clearInterval(clockTimer);
  autoTime = true;
  const timeInput = document.getElementById('time');
  timeInput.value = new Date().toTimeString().slice(0, 5);
  clockTimer = setInterval(() => {
    if (autoTime) timeInput.value = new Date().toTimeString().slice(0, 5);
  }, 1000);
}

document.getElementById('time').addEventListener('input', () => {
  autoTime = false;
});

async function init() {
  document.getElementById('date').value = new Date().toISOString().slice(0, 10);
  startClock();
  try {
    await liff.init({ liffId: LIFF_ID });
    if (!liff.isLoggedIn()) {
      liff.login();
      return;
    }
    const profile = await liff.getProfile();
    userId = profile.userId;
    document.getElementById('userInfo').textContent = profile.displayName;
  } catch (e) {
    document.getElementById('userInfo').textContent = "โหมดทดสอบ (ยังไม่ได้ตั้งค่า LIFF_ID)";
  }
  await loadRecords();
  renderTable();
}

async function loadRecords() {
  try {
    const raw = localStorage.getItem('bp_' + userId);
    records = raw ? JSON.parse(raw) : [];
  } catch (e) {
    records = [];
  }
}

async function saveRecords() {
  try {
    localStorage.setItem('bp_' + userId, JSON.stringify(records));
  } catch (e) {
    alert("บันทึกข้อมูลไม่สำเร็จ");
  }
}

document.getElementById('bpForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const record = {
    id: Date.now().toString(),
    date: document.getElementById('date').value,
    time: document.getElementById('time').value,
    systolic: Number(document.getElementById('systolic').value),
    diastolic: Number(document.getElementById('diastolic').value),
    pulse: document.getElementById('pulse').value ? Number(document.getElementById('pulse').value) : null,
    note: document.getElementById('note').value.trim()
  };
  records.push(record);
  records.sort((a, b) => (a.date + a.time).localeCompare(b.date + b.time));
  await saveRecords();
  renderTable();
  if (document.getElementById('chartView').style.display !== 'none') renderChart();
  e.target.reset();
  document.getElementById('date').value = new Date().toISOString().slice(0, 10);
  startClock();
});

function renderTable() {
  const tbody = document.querySelector('#bpTable tbody');
  tbody.innerHTML = '';
  [...records].reverse().forEach(r => {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td>${r.date}</td><td>${r.time}</td><td>${r.systolic}</td><td>${r.diastolic}</td><td>${r.pulse ?? ''}</td><td>${r.note || ''}</td><td><button data-id="${r.id}" class="del">ลบ</button></td>`;
    tbody.appendChild(tr);
  });
  tbody.querySelectorAll('.del').forEach(btn => {
    btn.addEventListener('click', async () => {
      records = records.filter(r => r.id !== btn.dataset.id);
      await saveRecords();
      renderTable();
      renderChart();
    });
  });
}

function renderChart() {
  const ctx = document.getElementById('bpChart');
  const labels = records.map(r => `${r.date} ${r.time}`);
  if (chartInstance) chartInstance.destroy();
  chartInstance = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'บน', data: records.map(r => r.systolic), borderColor: '#c0392b', tension: 0.2 },
        { label: 'ล่าง', data: records.map(r => r.diastolic), borderColor: '#2980b9', tension: 0.2 }
      ]
    },
    options: { responsive: true }
  });
}

function switchTab(tab) {
  const isTable = tab === 'table';
  document.getElementById('tableView').style.display = isTable ? 'block' : 'none';
  document.getElementById('chartView').style.display = isTable ? 'none' : 'block';
  document.getElementById('tabTable').classList.toggle('active', isTable);
  document.getElementById('tabChart').classList.toggle('active', !isTable);
  if (!isTable) renderChart();
}

document.getElementById('tabTable').addEventListener('click', () => switchTab('table'));
document.getElementById('tabChart').addEventListener('click', () => switchTab('chart'));

init();
</script>
</body>
</html>
